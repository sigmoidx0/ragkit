# --- Secrets ---
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string

# --- Optional overrides ---
# Uncomment to use Postgres instead of the SQLite default
# DATABASE_URL=postgresql+psycopg://ragkit:ragkit@localhost:5432/ragkit

# Qdrant (only if secured)
# VECTORSTORE_API_KEY=

# Embedding provider credentials (only if used)
# EMBEDDING_API_KEY=

# Bootstrap admin password (used on first run if no users exist)
INITIAL_ADMIN_PASSWORD=admin1234

# Shared token the MCP adapter uses to talk to the REST server
MCP_SERVICE_TOKEN=change-me-mcp-service-token
