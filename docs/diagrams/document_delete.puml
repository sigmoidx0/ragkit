@startuml Document Delete

title DELETE /services/{service_id}/documents/{id} — 문서 삭제

actor Client
participant "FastAPI\n(documents.py)" as API
participant "services/\ndocuments.py" as SVC
participant "indexing.py" as IDX
participant "Storage\n(get_storage())" as FS
participant "VectorStore" as QD
database "SQLite/PG\n(DB)" as DB

Client -> API : DELETE /services/{service_id}/documents/{id}
activate API

API -> DB : GET Document by id
DB --> API : document

API -> SVC : delete_document(document)
activate SVC

SVC -> IDX : clear_document_index(document)
activate IDX
IDX -> QD : delete_document(document_id)\n[payload filter]
activate QD
QD --> IDX : ok
deactivate QD
deactivate IDX

SVC -> FS : storage.delete_document_dir(document_id)
activate FS
note right of FS
  shutil.rmtree (ignore_errors=True)
  documents/{id}/ 폴더 전체 삭제
end note
FS --> SVC : ok
deactivate FS

deactivate SVC

API -> DB : db.delete(document)
note right of DB
  ON DELETE CASCADE로
  Chunk rows도 삭제
  (현재 Chunk 모델은 RDB에 없음)
end note

API -> DB : COMMIT

API --> Client : 204 No Content

deactivate API

@enduml
