@startuml Document Replace

title POST /services/{service_id}/documents/{id}/replace — 문서 교체

actor Client
participant "FastAPI\n(documents.py)" as API
participant "services/\ndocuments.py" as SVC
participant "Storage\n(get_storage())" as FS
participant "loaders.py\n(ingest)" as LDR
participant "indexing.py" as IDX
participant "VectorStore" as QD
database "SQLite/PG\n(DB)" as DB

Client -> API : POST /services/{service_id}/documents/{id}/replace\n(file)
activate API

API -> DB : GET Document by id
DB --> API : document

API -> IDX : clear_document_index(document)
activate IDX
IDX -> QD : delete_document(document_id)\n[payload filter]
QD --> IDX : ok
deactivate IDX

API -> SVC : delete_document_dir(document_id)
activate SVC
SVC -> FS : storage.delete_document_dir(document_id)
note right of FS #pink
  ⚠ 여기서 실패하면 구 벡터는 삭제됐으나
  구 파일은 남는 불일치 발생 가능
end note
FS --> SVC : ok
deactivate SVC

API -> SVC : save_document_file(document, new_file, filename, content_type)
activate SVC
SVC -> FS : storage.save_document_file(document_id, filename, source)
FS --> SVC : StoredFile
note right of SVC
  document 필드 직접 업데이트
end note
deactivate SVC

API -> DB : flush (status=pending, error=None)

API -> FS : storage.as_local_path(file_path)
activate FS
FS --> API : local path (context manager)
deactivate FS

API -> LDR : convert_to_documents(local_path)
activate LDR
LDR --> API : list[Document]
deactivate LDR

API -> IDX : index_document(db, document, docs)
activate IDX
IDX --> API : (status=indexed)
deactivate IDX

API -> DB : COMMIT

API --> Client : 200 DocumentOut

deactivate API

@enduml
