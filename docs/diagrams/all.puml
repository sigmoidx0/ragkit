@startuml Document Create

title POST /services/{service_id}/documents — 문서 업로드 & 인덱싱

actor Client
participant "FastAPI\n(documents.py)" as API
participant "services/\ndocuments.py" as SVC
participant "Storage\n(get_storage())" as FS
participant "loaders.py\n(ingest)" as LDR
participant "indexing.py" as IDX
participant "chunking.py\n(ingest)" as ING
participant "Embedder" as EMB
participant "VectorStore" as QD
database "SQLite/PG\n(DB)" as DB

Client -> API : POST /services/{service_id}/documents\n(file, title, description)
activate API

API -> DB : INSERT Document\n(status=pending, file_path="")
activate DB
DB --> API : document.id
deactivate DB

API -> SVC : save_document_file(document, file, filename, content_type)
activate SVC
SVC -> FS : storage.save_document_file(document_id, filename, source)
activate FS
FS --> SVC : StoredFile(stored_path, size_bytes, sha256)
deactivate FS
note right of SVC : document 필드(file_path, size_bytes,\nsha256)를 직접 업데이트
deactivate SVC

API -> DB : flush

API -> FS : storage.as_local_path(file_path)
activate FS
FS --> API : local path (context manager)
deactivate FS

API -> LDR : convert_to_documents(local_path)
activate LDR
LDR --> API : list[Document]
deactivate LDR

API -> IDX : index_document(db, document, docs)
activate IDX

IDX -> DB : flush (status=chunking)

IDX -> ING : strategy.split(docs)
activate ING
ING --> IDX : list[ChunkRecord]
deactivate ING

IDX -> DB : flush (status=embedding)

IDX -> EMB : embed_documents(texts)
activate EMB
EMB --> IDX : list[vector]
deactivate EMB

IDX -> QD : upsert(point_ids, vectors, payloads)
activate QD
QD --> IDX : ok
deactivate QD

IDX -> DB : flush (status=indexed)

alt 인덱싱 중 예외 발생
  IDX -> QD : delete_points(inserted_point_ids)
  IDX --> API : raise RuntimeError
  API -> SVC : delete_document_dir(document_id)
  API --> Client : 500 indexing failed
end

deactivate IDX

API -> DB : COMMIT
DB --> API : ok

API --> Client : 201 DocumentOut

deactivate API

@enduml

newpage

@startuml Document Replace

title POST /services/{service_id}/documents/{id}/replace — 문서 교체

actor Client
participant "FastAPI\n(documents.py)" as API
participant "services/\ndocuments.py" as SVC
participant "Storage\n(get_storage())" as FS
participant "loaders.py\n(ingest)" as LDR
participant "indexing.py" as IDX
participant "VectorStore" as QD
database "SQLite/PG\n(DB)" as DB

Client -> API : POST /services/{service_id}/documents/{id}/replace\n(file)
activate API

API -> DB : GET Document by id
DB --> API : document

API -> IDX : clear_document_index(document)
activate IDX
IDX -> QD : delete_document(document_id)
QD --> IDX : ok
deactivate IDX

API -> SVC : delete_document_dir(document_id)
activate SVC
SVC -> FS : storage.delete_document_dir(document_id)
note right of FS #pink
  ⚠ 여기서 실패하면 구 벡터는 삭제됐으나
  구 파일은 남는 불일치 발생 가능
end note
FS --> SVC : ok
deactivate SVC

API -> SVC : save_document_file(document, new_file, filename, content_type)
activate SVC
SVC -> FS : storage.save_document_file(document_id, filename, source)
FS --> SVC : StoredFile
note right of SVC : document 필드 직접 업데이트
deactivate SVC

API -> DB : flush (status=pending, error=None)

API -> FS : storage.as_local_path(file_path)
activate FS
FS --> API : local path (context manager)
deactivate FS

API -> LDR : convert_to_documents(local_path)
activate LDR
LDR --> API : list[Document]
deactivate LDR

API -> IDX : index_document(db, document, docs)
activate IDX
IDX --> API : (status=indexed)
deactivate IDX

API -> DB : COMMIT

API --> Client : 200 DocumentOut

deactivate API

@enduml

newpage

@startuml Document Delete

title DELETE /services/{service_id}/documents/{id} — 문서 삭제

actor Client
participant "FastAPI\n(documents.py)" as API
participant "services/\ndocuments.py" as SVC
participant "indexing.py" as IDX
participant "Storage\n(get_storage())" as FS
participant "VectorStore" as QD
database "SQLite/PG\n(DB)" as DB

Client -> API : DELETE /services/{service_id}/documents/{id}
activate API

API -> DB : GET Document by id
DB --> API : document

API -> SVC : delete_document(document)
activate SVC
SVC -> IDX : clear_document_index(document)
activate IDX
IDX -> QD : delete_document(document_id)
QD --> IDX : ok
deactivate IDX
SVC -> FS : storage.delete_document_dir(document_id)
FS --> SVC : ok
deactivate SVC

API -> DB : db.delete(document)
API -> DB : COMMIT

API --> Client : 204 No Content

deactivate API

@enduml

newpage

@startuml Search

title POST /services/{service_id}/search — 의미 기반 벡터 검색

actor Client
participant "FastAPI\n(search.py)" as API
participant "chain.py\n(rag)" as CHAIN
participant "Embedder" as EMB
participant "VectorStore" as QD
database "SQLite/PG\n(DB)" as DB

Client -> API : POST /services/{service_id}/search\n{query, top_k?, document_id?}
activate API

API -> CHAIN : run_search(db, SearchQuery)
activate CHAIN

CHAIN -> EMB : embed_query(query)
activate EMB
EMB --> CHAIN : vector[float]
deactivate EMB

CHAIN -> QD : search(vector, top_k, service_id, document_id?)
activate QD
QD --> CHAIN : list[SearchHit]
deactivate QD

CHAIN -> DB : SELECT Document WHERE id IN (doc_ids)
activate DB
DB --> CHAIN : list[Document]
deactivate DB

CHAIN --> API : list[EnrichedHit]
deactivate CHAIN

API --> Client : 200 SearchResponse

deactivate API

@enduml
