@startuml Document Create

title POST /documents — 문서 업로드 & 인덱싱

actor Client
participant "FastAPI\n(documents.py)" as API
participant "FileStorage\n(local.py)" as FS
participant "indexing.py" as IDX
participant "pipeline.py\n(ingest)" as ING
participant "Embedder" as EMB
participant "QdrantStore" as QD
database "SQLite/PG\n(DB)" as DB

Client -> API : POST /documents\n(file, title, description)
activate API

API -> DB : INSERT Document\n(status=pending, file_path="")
activate DB
DB --> API : document.id
deactivate DB

API -> FS : save_document_file(document_id, file)
activate FS
note right of FS
  SHA-256 계산
  documents/{id}/{safe_filename} 저장
end note
FS --> API : StoredFile(relative_path, size_bytes, sha256)
deactivate FS

API -> DB : flush (file_path, size_bytes, sha256 업데이트)

API -> IDX : index_document(db, document)
activate IDX

IDX -> ING : ingest_file(abs_path)
activate ING
note right of ING
  확장자 기반 로더 선택
  (PDF→PyMuPDF, Office→Unstructured, txt→plain)
  RecursiveCharacterTextSplitter
end note
ING --> IDX : list[ChunkRecord]
deactivate ING

IDX -> EMB : embed_documents(texts)
activate EMB
EMB --> IDX : list[vector]
deactivate EMB

IDX -> QD : upsert(point_ids, vectors, payloads)
activate QD
note right of QD
  payload: document_id, ordinal,
           text, source_metadata
end note
QD --> IDX : ok
deactivate QD

IDX -> DB : flush (status=ready)

alt 인덱싱 중 예외 발생
  IDX -> QD : delete_points(inserted_point_ids)
  IDX -> DB : flush (status=failed, error=msg)
end

deactivate IDX

API -> DB : COMMIT (TxDbDep)
activate DB
DB --> API : ok
deactivate DB

API --> Client : 201 DocumentOut

deactivate API

@enduml
